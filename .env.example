# Supabase (35_Deployment.md § 5 — secrets nooit in de repo, dit is uitsluitend een sjabloon)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Basis-URL van de applicatie, gebruikt voor auth-redirects (wachtwoord-reset, e-mailbevestiging)
# Let op: moet exact overeenkomen met supabase/config.toml [auth] site_url /
# additional_redirect_urls, anders wijst Supabase Auth de redirect af.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Mapbox (14_RoutingEngine.md § 1, ADR-005) — uitsluitend server-side gebruikt
# (Edge Functions), nooit NEXT_PUBLIC_*: routing/geocoding gebeurt nooit in de client.
MAPBOX_ACCESS_TOKEN=<mapbox-access-token>

# Sentry (Sprint 10, observability-basis) — optioneel: zonder deze vars blijft
# Sentry volledig inert (geen events, geen build-fout). Activeren vereist een
# eigen Sentry-project. SENTRY_DSN/NEXT_PUBLIC_SENTRY_DSN zijn meestal gelijk
# (Sentry-DSN's zijn niet geheim); SENTRY_ORG/SENTRY_PROJECT/SENTRY_AUTH_TOKEN
# zijn alleen nodig voor source-map-upload bij een productiebuild.
SENTRY_DSN=<sentry-dsn>
NEXT_PUBLIC_SENTRY_DSN=<sentry-dsn>
SENTRY_ORG=<sentry-org-slug>
SENTRY_PROJECT=<sentry-project-slug>
SENTRY_AUTH_TOKEN=<sentry-auth-token>
